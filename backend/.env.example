# Configuração do backend BSS — copie para .env e preencha.
# Nunca commite o arquivo .env real (já está no .gitignore).

# === PostgreSQL do BSS (banco novo, limpo) ===
PG_HOST=localhost
PG_PORT=5432
PG_DB=bss
PG_USER=bss_app
PG_PASSWORD=

# === MySQL do SuiteCRM legado (somente leitura — pra sync) ===
# Deixe em branco enquanto não for usar.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB=suitecrm
MYSQL_USER=
MYSQL_PASSWORD=

# === Autenticação JWT ===
JWT_SECRET=troque-isto-por-uma-string-longa-e-aleatoria
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
